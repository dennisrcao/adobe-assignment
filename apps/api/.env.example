# Claude access via OpenRouter (default).
# Required when a product has no `input_assets/<id>/hero.{png,jpg,webp}` (GenAI hero prompt)
# or when `overlay_locale: es` is set (Spanish overlay translation).
OPENROUTER_API_KEY=sk-or-v1-...
ANTHROPIC_MODEL=anthropic/claude-sonnet-4.6

# Optional: use the Anthropic SDK directly instead of OpenRouter.
# If set, this takes precedence over OPENROUTER_API_KEY. Use a bare model id (e.g. `claude-sonnet-4-6`) in ANTHROPIC_MODEL.
# ANTHROPIC_API_KEY=sk-ant-...

# Luma Photon API (required when a product has no local hero)
LUMA_API_KEY=luma-...
LUMA_MODEL=photon-flash-1

# Optional: style reference image URLs (comma-separated)
LUMA_STYLE_REF_URLS=

# Logging
LOG_LEVEL=INFO

# FastAPI
DEBUG=false
